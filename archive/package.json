{
  "name": "realtor",
  "private": true,
  "workspaces": [
    "realtor-web/uilayers",
    "realtor-mobile"
  ],
  "scripts": {
    "web:dev": "npm run dev --workspace=realtor-web/uilayers",
    "mobile:dev": "npm run start --workspace=realtor-mobile",
    "dev": "npm run web:dev",
    "dev:all": "concurrently \"npm run web:dev\" \"npm run mobile:dev\"",
    "install:all": "npm install && cd realtor-web/uilayers && npm install && cd ../../realtor-mobile && npm install"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
