# ==============================================================================
# PROPERTISM REALTY ADVISORS - ENVIRONMENT VARIABLES
# ==============================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control!

# ==============================================================================
# DJANGO CORE SETTINGS
# ==============================================================================

# Generate a new secret key for production using:
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=your-secret-key-here-change-this-in-production

# Environment: development, staging, production
DJANGO_ENV=development

# Comma-separated list of allowed hosts
# Example: propertism.com,www.propertism.com,api.propertism.com
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# ==============================================================================
# DATABASE CONFIGURATION (PostgreSQL)
# ==============================================================================

DB_NAME=propertism_db
DB_USER=propertism_user
DB_PASSWORD=your-database-password-here
DB_HOST=localhost
DB_PORT=5432

# ==============================================================================
# EMAIL CONFIGURATION
# ==============================================================================

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password-here
DEFAULT_FROM_EMAIL=noreply@propertism.com
SERVER_EMAIL=server@propertism.com
ADMIN_EMAIL=admin@propertism.com

# ==============================================================================
# CORS SETTINGS
# ==============================================================================

# Comma-separated list of allowed origins
# Example: https://propertism.com,https://www.propertism.com
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:19000

# ==============================================================================
# REDIS CACHE (Optional - for production)
# ==============================================================================

REDIS_URL=redis://127.0.0.1:6379/1

# ==============================================================================
# SECURITY SETTINGS
# ==============================================================================

# Custom admin URL (change from default /admin/)
ADMIN_URL=secure-admin-panel

# ==============================================================================
# THIRD-PARTY SERVICES (Optional)
# ==============================================================================

# Google Analytics
GOOGLE_ANALYTICS_ID=

# Sentry Error Tracking
SENTRY_DSN=

# AWS S3 (for media files in production)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=us-east-1
